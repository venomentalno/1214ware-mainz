{
  "schemaVersion": 1,
  "id": "botclient",
  "version": "${version}",
  "name": "BotClient",
  "description": "Advanced bot client for Minecraft",
  "authors": ["BotClient Team"],
  "contact": {
    "sources": "https://github.com/yourrepo/botclient"
  },
  "license": "MIT",
  "icon": "assets/botclient/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.botclient.BotClientMod"],
    "client": ["com.botclient.BotClientClient"]
  },
  "mixins": [
    "botclient.mixins.json"
  ],
  "accessWidener": "botclient.accesswidener",
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.4",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_310": ["com/botclient/MinecraftContext"]
    }
  }
}
